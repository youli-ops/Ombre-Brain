# Rust shadow-kernel build output. ombre-kernel is currently a library crate,
# so its generated Cargo.lock is not a release lockfile.
kernel/rust/**/target/
kernel/rust/ombre-kernel/Cargo.lock
.tmp/ombre-nodes-v2.yaml
.tmp/
